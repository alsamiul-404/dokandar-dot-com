# PostgreSQL — Supabase: use Transaction pooler (port 6543) for the app runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXTAUTH_SECRET="generate-a-long-random-string-for-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: override API base for the browser client (defaults to same-origin "/api")
# NEXT_PUBLIC_API_URL="/api"

# SSL Wireless (ISMS+ JSON v3)
SSL_WIRELESS_API_KEY=""
SSL_WIRELESS_SENDER_ID=""
SSL_WIRELESS_BASE_URL="https://smsplus.sslwireless.com"
SSL_WIRELESS_MODE="ismsplus"
SMS_DISABLE_SEND="false"
AUTH_ALLOW_MOCK_OTP="false"
AUTH_MOCK_OTP_CODE="123456"

# =============================================================================
# CLOUD INFRA (use the SAME values locally and on Vercel — no Docker required)
# =============================================================================

# --- Redis: Upstash (recommended for Vercel + local dev) ---
# 1. https://console.upstash.com → Create database → REST API
# 2. Copy REST URL + REST TOKEN into .env AND Vercel Environment Variables
UPSTASH_REDIS_REST_URL="https://YOUR-REGION-YOUR-ID.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXXXxxx..."

# Optional alternative: Redis Cloud / other TCP URL (not needed if Upstash is set)
# REDIS_URL="rediss://default:PASSWORD@redis-12345.c123.us-east-1-1.ec2.cloud.redislabs.com:12345"

# --- RabbitMQ: CloudAMQP ---
# 1. https://www.cloudamqp.com → Create instance (free Little Lemur plan)
# 2. Copy AMQP URL (starts with amqps://) — use in .env AND Vercel
RABBITMQ_URL="amqps://USER:PASS@HOST/VHOST"

# Background worker: deploy `npm run worker` on Railway/Render/Fly with SAME env as production.
# Locally: `npm run worker` in a second terminal while `npm run dev` runs.

# Verify setup: npm run check:infra
