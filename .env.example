# PostgreSQL — Supabase: use Transaction pooler (port 6543) for the app runtime.
# Username is usually postgres.<project-ref> — copy from Supabase → Settings → Database.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Prisma `migrate` / `db push` needs a DIRECT connection (not pgbouncer). In Supabase use the
# "URI" whose host is db.PROJECT_REF.supabase.co (user is `postgres`, same DB password).
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
NEXTAUTH_SECRET="generate-a-long-random-string-for-production"
# Production / `npm run start`: set to your public URL. Local `npm run dev` overrides NEXTAUTH_URL to match `-p`.
NEXTAUTH_URL="http://localhost:3000"
# Omit PORT for local dev (`npm run dev` uses `-p` from scripts/dev.mjs). For `npm run start`, set e.g. PORT=3000.

# Optional: override API base for the browser client (defaults to same-origin "/api")
# NEXT_PUBLIC_API_URL="/api"

# SSL Wireless (ISMS+ JSON v3) — https://ismsplus.sslwireless.com
SSL_WIRELESS_API_KEY=""
SSL_WIRELESS_SENDER_ID=""
SSL_WIRELESS_BASE_URL="https://smsplus.sslwireless.com"
# Optional: "legacy" for pushapi form POST (needs SSL_WIRELESS_LEGACY_USER / SSL_WIRELESS_LEGACY_PASS)
SSL_WIRELESS_MODE="ismsplus"
SSL_WIRELESS_LEGACY_USER=""
SSL_WIRELESS_LEGACY_PASS=""
SSL_WIRELESS_LEGACY_URL=""

# Skip real HTTP SMS (OTP still works via console log + mock code in dev)
SMS_DISABLE_SEND="false"

# In production, mock OTP is off unless AUTH_ALLOW_MOCK_OTP=true
AUTH_ALLOW_MOCK_OTP="false"
AUTH_MOCK_OTP_CODE="123456"
